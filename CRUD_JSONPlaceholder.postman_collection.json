    {
      "name": "POST — Create New Post",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ✅ Status Code Check",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 🔍 Response Body Assertions",
              "pm.test(\"Response has id\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "});",
              "",
              "pm.test(\"Title matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.title).to.eql(\"Xavier Test Post\");",
              "});",
              "",
              "pm.test(\"Body matches request\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.body).to.eql(\"This is a test post body\");",
              "});",
              "",
              "// 💾 Store new post id to environment variable",
              "var jsonData = pm.response.json();",
              "pm.environment.set(\"new_post_id\", jsonData.id);",
              "",
              "// ⏱️ Response Time Check",
              "pm.test(\"Response time is less than 500ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(500);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Xavier Test Post\",\n  \"body\": \"This is a test post body\",\n  \"userId\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      }
